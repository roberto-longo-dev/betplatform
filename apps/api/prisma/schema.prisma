// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String         @id @default(cuid())
  email          String         @unique
  passwordHash   String
  selfExcluded   Boolean        @default(false)
  excludedUntil  DateTime?
  createdAt      DateTime       @default(now())
  tokens         RefreshToken[]
  sessions       UserSession[]
  depositLimit   DepositLimit?
  auditLogs      AuditLog[]
}

/// Opaque refresh tokens stored server-side to enable revocation.
/// Token rotation: each /auth/refresh invalidates the submitted token
/// and issues a new one, making stolen tokens detectable.
model RefreshToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

/// Tracks active gambling sessions for responsible gambling enforcement.
/// selfExcluded flag is set when a user requests self-exclusion.
model UserSession {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  startedAt    DateTime  @default(now())
  endedAt      DateTime?
  selfExcluded Boolean   @default(false)

  @@index([userId])
}

/// Deposit limit per user. If a user requests a higher limit, it is held
/// in pendingAmount/pendingFrom and applied after a 7-day cooling-off period.
model DepositLimit {
  id            String    @id @default(cuid())
  userId        String    @unique
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount        Decimal   @db.Decimal(12, 2)
  period        String    // "daily" | "weekly" | "monthly"
  pendingAmount Decimal?  @db.Decimal(12, 2)
  pendingFrom   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

/// Immutable audit trail for responsible gambling actions and financial events.
model AuditLog {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action        String
  amount        Decimal? @db.Decimal(12, 2)
  balanceBefore Decimal? @db.Decimal(12, 2)
  balanceAfter  Decimal? @db.Decimal(12, 2)
  metadata      Json?
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}
