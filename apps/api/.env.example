# PostgreSQL — run `docker compose up -d` to start locally
DATABASE_URL=

# Redis — run `docker compose up -d` to start locally
REDIS_URL=

# JWT secrets — use separate long random strings in production
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# Odds API — https://the-odds-api.com (free tier: 500 requests/month)
# Leave empty to use built-in mock data instead
ODDS_API_KEY=

# CORS — comma-separated origins for production, e.g. https://your-app.vercel.app
CORS_ORIGIN=http://localhost:3000

# Server
NODE_ENV=development
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=info
