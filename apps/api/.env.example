# PostgreSQL — run `docker compose up -d` to start locally
DATABASE_URL=

# Redis — run `docker compose up -d` to start locally
REDIS_URL=

# JWT secrets — use separate long random strings in production
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# Server
NODE_ENV=development
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=info
